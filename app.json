{
  "expo": {
    "name": "AllDayFade",
    "slug": "adf",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "adf",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alldayfade.app"
    },
    "android": {
      "package": "com.alldayfade.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D"
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
